# Environment Variables for Simon Tibrum Portfolio
# Copy this file and rename to .env.local for local development
# Add these variables in Vercel Dashboard under Project Settings > Environment Variables

# ============================================================
# SUPABASE — Required for contact form & database
# ============================================================
# Get these from: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================================
# OPTIONAL — Site metadata
# ============================================================
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app
